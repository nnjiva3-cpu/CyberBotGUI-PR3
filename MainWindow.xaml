<Window x:Class="CyberBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" Height="650" Width="950"
        Background="#0d0d1a" WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#111133" CornerRadius="10" Padding="15" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="🔐 CYBERSECURITY AWARENESS BOT" 
                           FontSize="24" FontWeight="Bold" 
                           Foreground="#00ff88" HorizontalAlignment="Center"
                           FontFamily="Consolas"/>
                <TextBlock FontFamily="Consolas" FontSize="11" 
                           Foreground="#00ff88" HorizontalAlignment="Center"
                           TextAlignment="Center" Margin="0,5,0,5"
                           Text="[ C Y B E R - B O T | S T A Y S A F E O N L I N E ]"/>
                <TextBlock Text="Your personal guide to staying safe in the digital world" 
                           FontSize="12" Foreground="#aaaaaa" 
                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Quick Topic Buttons -->
        <Border Grid.Row="1" Background="#111133" CornerRadius="10" Padding="10" Margin="0,0,0,10">
            <WrapPanel HorizontalAlignment="Center">
                <Button Content="🔑 Passwords" Margin="5" Padding="8,5" Click="TopicButton_Click"
                        Background="#003344" Foreground="#00ff88" BorderBrush="#00ff88" 
                        BorderThickness="1" Cursor="Hand"/>
                <Button Content="🎣 Phishing" Margin="5" Padding="8,5" Click="TopicButton_Click"
                        Background="#003344" Foreground="#00ff88" BorderBrush="#00ff88"
                        BorderThickness="1" Cursor="Hand"/>
                <Button Content="🌐 Safe Browsing" Margin="5" Padding="8,5" Click="TopicButton_Click"
                        Background="#003344" Foreground="#00ff88" BorderBrush="#00ff88"
                        BorderThickness="1" Cursor="Hand"/>
                <Button Content="🦠 Malware" Margin="5" Padding="8,5" Click="TopicButton_Click"
                        Background="#003344" Foreground="#00ff88" BorderBrush="#00ff88"
                        BorderThickness="1" Cursor="Hand"/>
                <Button Content="🔒 Privacy" Margin="5" Padding="8,5" Click="TopicButton_Click"
                        Background="#003344" Foreground="#00ff88" BorderBrush="#00ff88"
                        BorderThickness="1" Cursor="Hand"/>
                <Button Content="⚠️ Scams" Margin="5" Padding="8,5" Click="TopicButton_Click"
                        Background="#003344" Foreground="#00ff88" BorderBrush="#00ff88"
                        BorderThickness="1" Cursor="Hand"/>
            </WrapPanel>
        </Border>

        <!-- Chat Area -->
        <Border Grid.Row="2" Background="#111133" CornerRadius="10" Padding="5" Margin="0,0,0,10">
            <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                <RichTextBox x:Name="ChatBox" Background="#111133" 
                             Foreground="White" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="13"
                             BorderThickness="0" Padding="10"/>
            </ScrollViewer>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="3" Background="#111133" CornerRadius="10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InputBox" Grid.Column="0"
                         Background="#0d0d1a" Foreground="White"
                         FontSize="13" Padding="10" Height="40"
                         BorderBrush="#00ff88" BorderThickness="1"
                         CaretBrush="White"
                         KeyDown="InputBox_KeyDown"/>
                <Button x:Name="SendButton" Grid.Column="1"
                        Content="SEND ➤" Width="90" Margin="8,0,0,0"
                        Background="#00ff88" Foreground="#0d0d1a"
                        FontWeight="Bold" FontSize="13" Height="40"
                        Click="SendButton_Click" Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>
